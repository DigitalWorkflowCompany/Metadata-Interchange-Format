{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ns.the-dwc.com/sidecar/v0.1/locks.schema.json",
  "title": "DWC Sidecar — Locks",
  "description": "Signed lock records — a derived view of 'lock'/'unlock' events. Carried inside an OMC Asset's customData under domain 'dwc.sidecar.locks'. Cross-reference to the corresponding signed event entry is enforced outside JSON Schema.",

  "type": "array",
  "minItems": 0,
  "items": { "$ref": "#/$defs/lock" },

  "$defs": {
    "urn": {
      "type": "string",
      "pattern": "^urn:[a-z0-9][a-z0-9-]{0,31}:[^\\s]+$"
    },

    "signature": {
      "type": "object",
      "required": ["alg", "kid", "value"],
      "additionalProperties": false,
      "properties": {
        "alg":   { "type": "string", "enum": ["ed25519", "ecdsa-p256", "rsa-pss"] },
        "kid":   { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },

    "lock": {
      "type": "object",
      "required": ["target", "scope", "by", "at", "sig"],
      "additionalProperties": false,
      "properties": {
        "target": { "$ref": "#/$defs/urn" },
        "scope":  { "type": "string", "enum": ["artifact", "entity", "field"] },
        "field":  {
          "type": "string",
          "description": "JSON Pointer to the locked field. Required only when scope = 'field'.",
          "pattern": "^(/[^/~]*(~[01][^/~]*)*)+$"
        },
        "by":     { "$ref": "#/$defs/urn" },
        "at":     { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "sig":    { "$ref": "#/$defs/signature" }
      },
      "allOf": [
        {
          "if":   { "properties": { "scope": { "const": "field" } } },
          "then": { "required": ["field"] }
        }
      ]
    }
  }
}
